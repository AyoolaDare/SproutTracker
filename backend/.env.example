# Sprout Track Backend Production Environment
# Copy these keys into Render > sprout-track-api > Environment.
# Do not commit a real .env file with live secrets.

# =============================================================================
# 1. RENDER / FASTAPI APP
# =============================================================================
APP_NAME=Sprout Track
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false

# Render backend hostnames. Include every hostname used to call the API.
TRUSTED_HOSTS=sprouttracker.onrender.com,sprout-track-api.onrender.com

# Flutter web/PWA URLs. Include apex and www if both can open in browser.
FRONTEND_URL=https://www.sprouttracker.name.ng
CORS_ORIGINS=https://www.sprouttracker.name.ng,https://sprouttracker.name.ng

# Generate two different long secrets. Minimum 32 chars each.
# PowerShell example:
# -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 64 | ForEach-Object {[char]$_})
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Optional but recommended. Leave blank until Sentry is ready.
SENTRY_DSN=

# =============================================================================
# 2. SUPABASE
# =============================================================================
# Supabase > Project Settings > Database > Connection string.
# Use the Transaction Pooler URI for Render if possible.
# DATABASE_URL can be postgresql://...; app converts it to asyncpg.
DATABASE_URL=postgresql://postgres.REPLACE_PROJECT_REF:REPLACE_PASSWORD@aws-0-REPLACE_REGION.pooler.supabase.com:6543/postgres

# Same Supabase URI, but keep it as plain postgresql:// for Alembic migrations.
DATABASE_URL_SYNC=postgresql://postgres.REPLACE_PROJECT_REF:REPLACE_PASSWORD@aws-0-REPLACE_REGION.pooler.supabase.com:6543/postgres
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5

# Supabase > Project Settings > API.
SUPABASE_URL=https://REPLACE_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=sprout-track

# =============================================================================
# 3. UPSTASH REDIS
# =============================================================================
# Upstash > Redis database > Details > Redis URL.
# Prefer the TLS rediss:// URL.
REDIS_URL=rediss://default:REPLACE_PASSWORD@REPLACE_HOST.upstash.io:6379
REDIS_REQUIRED=true
REDIS_PREFIX=sprout-track

# Rate limits and cache TTLs.
RATE_LIMIT_LOGIN=5
RATE_LIMIT_API=60
RATE_LIMIT_WINDOW_SECONDS=60
DASHBOARD_CACHE_SECONDS=60

# =============================================================================
# 4. OPTIONAL SMTP
# =============================================================================
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_SMTP_LOGIN
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
SMTP_FROM_EMAIL=no-reply@yourdomain.com
SMTP_FROM_NAME=Sprout Track

# Google SSO
GOOGLE_CLIENT_ID=
